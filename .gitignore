# --- Vivado Temporary/Junk Files ---
*.log
*.jou
*.str
*.os
*.pb
*.jou
.Xil/
vsswork/

# --- Simulation Files (Rất nặng, không nên đưa lên) ---
xsim.dir/
*.vgl
*.veo
*.vhd
*.vho
*.vlog
*.vcd
*.wdb
*.wcfg

# --- Synthesis & Implementation Outputs ---
# Chỉ nên giữ lại source code, không giữ file chạy (bitstream có thể giữ tùy bạn)
*.jou
*.mmi
*.bit
*.bin
*.ltx
*.sysdef
*.hwdef

# --- Project Specific Directories ---
# Thư mục chứa dữ liệu biên dịch của Vivado (Rất lớn)
<tên_project>.cache/
<tên_project>.hw/
<tên_project>.ip_user_files/
<tên_project>.runs/
<tên_project>.sim/
<tên_project>.srcs/sources_1/bd/*/hdl/
<tên_project>.gen/

# --- SDK / Vitis Files ---
.metadata/
.sdk/
SDK_export/
workspace/

# --- OS Files ---
Thumbs.db
.DS_Store